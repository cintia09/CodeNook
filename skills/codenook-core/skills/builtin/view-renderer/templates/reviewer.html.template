<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8">
<title>{{title}}</title>
<style>
body{font:15px/1.65 -apple-system,Segoe UI,Roboto,sans-serif;max-width:880px;margin:2em auto;padding:0 1.2em;color:#1f2937}
h1{font-size:1.4em;margin:.2em 0 .8em;color:#0f172a}
h2{font-size:1.15em;margin:1.4em 0 .4em;color:#0f172a}
h3{font-size:1em;margin:1.2em 0 .3em;color:#0f172a}
p{margin:.55em 0}
a{color:#2563eb;text-decoration:none}
a:hover{text-decoration:underline}
ul,ol{padding-left:1.6em;margin:.5em 0}
li{margin:.2em 0}
blockquote{border-left:3px solid #cbd5e1;padding:.2em .9em;color:#475569;margin:.7em 0;background:#f8fafc;border-radius:0 4px 4px 0}
code{background:#eef2ff;color:#3730a3;padding:.05em .35em;border-radius:3px;font-family:Menlo,Consolas,monospace;font-size:.92em}
pre{background:#1e293b;color:#e2e8f0;padding:.9em 1.1em;border-radius:6px;overflow-x:auto;font-family:Menlo,Consolas,monospace;font-size:12.5px;line-height:1.55}
pre code{background:none;color:inherit;padding:0;font-size:inherit}
pre.mermaid{background:#fafafa;color:#1f2937;padding:.7em;border:1px solid #e5e7eb;text-align:center}
.footer{margin-top:2.5em;padding-top:1em;border-top:1px solid #e5e7eb;color:#64748b;font-size:.85em}
.footer code{background:none;color:#475569;padding:0}
</style>
</head><body>
{{body}}
<div class="footer">Source: <code>{{src_path}}</code></div>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script>if(window.mermaid){mermaid.initialize({startOnLoad:true,theme:'default'});}</script>
</body></html>
