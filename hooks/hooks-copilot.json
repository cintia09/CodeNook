{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-session-start.sh",
        "comment": "Multi-Agent Framework: check agent state and pending items on session start",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/security-scan.sh",
        "comment": "Security: scan staged files for secrets before git commit/push",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-pre-tool-use.sh",
        "comment": "Multi-Agent Framework: enforce agent boundaries",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-post-tool-use.sh",
        "comment": "Multi-Agent Framework: audit log + auto-dispatch",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/agent-staleness-check.sh",
        "comment": "Multi-Agent Framework: detect stale tasks",
        "timeoutSec": 5
      }
    ]
  }
}
